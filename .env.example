# D.R.O.N.A. - environment configuration template
# Copy this to .env and customize. .env is gitignored.

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/drona.log

# === Data paths ===
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_MANUAL_DIR=data/manual_collection

# === LLM backend ===
# ollama (default)  : GGUF via the local Ollama server - fastest on CPU-only PCs.
# transformers      : weights straight from Hugging Face (like the embedding
#                     models), incl. the trained LoRA adapter with NO GGUF
#                     conversion - best on any CUDA GPU (Colab demo, RTX box).
# Both are local + open-source: the no-paid-API invariant (C4) holds either way.
LLM_BACKEND=ollama
HF_MODEL=Qwen/Qwen3-4B-Instruct-2507
HF_ADAPTER_PATH=models/advising-lora
HF_LOAD_4BIT=true

# === LLM (Ollama, local) ===
OLLAMA_HOST=http://localhost:11434
# Primary = Qwen3-4B-Instruct-2507 (strongest ~4B open instruct, Apache-2.0).
#   ollama pull qwen3:4b-instruct-2507-q4_K_M
# If that tag is unavailable in your Ollama library version, use one of:
#   qwen3:4b   |   qwen2.5:3b-instruct-q4_K_M   |   phi3.5:3.8b-mini-instruct-q4_K_M
OLLAMA_MODEL=qwen3:4b-instruct-2507-q4_K_M
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
# Fast mode: keep the model loaded between requests + bound the context window.
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_CTX=4096

# === Embeddings ===
CURRICULUM_EMBED_MODEL=BAAI/bge-small-en-v1.5
CAREER_EMBED_MODEL=TechWolf/JobBERT-v2
# v2-m3: more accurate + multilingual; ~2x slower on CPU than the old
# bge-reranker-base (fine - reranking runs once per query, the LLM dominates).
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# === Vector store ===
CHROMA_DIR=data/chromadb
CHROMA_COLLECTION_PREFIX=drona

# === Retrieval ===
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
HYBRID_DENSE_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4

# === Tier prioritization (anti-anchoring) ===
TIER_NEPAL_BOOST=1.5
TIER_REGIONAL_BOOST=1.1
TIER_INTERNATIONAL_BOOST=1.0
TIER_SYNTHETIC_PENALTY=0.7

# === Fallback LLM (Ollama, local) ===
# Tried only if the primary model isn't loaded; still local, still no API cost.
# (Optional) pull it with: ollama pull qwen2.5:3b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M

# === PostgreSQL 16 + pgvector (production vector + relational store) ===
# Matches docker-compose.yml service. pgvector extension is created by migration.
POSTGRES_DSN=postgresql+psycopg://drona:drona@localhost:5432/drona
POSTGRES_USER=drona
POSTGRES_PASSWORD=drona
POSTGRES_DB=drona
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Pinecone (managed cloud vector store, optional) ===
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_CURRICULUM=drona-curriculum
PINECONE_INDEX_CAREER=drona-career

# === Vector store backend selector ===
# One of: chroma (default, local) | pgvector | pinecone
VECTOR_BACKEND=chroma

# === Google Gemini API - OFFLINE USE ONLY ===
# Allowed for: synthetic Q&A generation, offline eval-set creation.
# FORBIDDEN in the live advising request path (preserves "local-only" claim).
# The code enforces this via ALLOW_GEMINI_IN_REQUEST_PATH=false; do not flip it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
ALLOW_GEMINI_IN_REQUEST_PATH=false

# === Google Vertex AI Agent Builder (OPTIONAL, feature-flagged, default OFF) ===
# Alternative cloud orchestrator backend for thesis demonstration only.
ENABLE_VERTEX_AGENT=false
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# === FastAPI backend ===
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
