<?xml version="1.0"?>
<!--
  D.R.O.N.A. simulated humanoid (upper body) - ROS2 Humble.

  Head + torso + a 6-DOF right arm. Joint names mirror
  drona.interaction.demonstration.JOINT_NAMES so /drona/joint_states drives this
  model unchanged in RViz / Gazebo / Isaac. Geometry uses primitives (no mesh
  assets) and approximate SO-100-class link dimensions; inertials are provided so
  the model is valid in physics simulators.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="drona_humanoid">

  <!-- Simulation feature gates (harmless elsewhere: RViz/Isaac ignore <gazebo>).
       use_gz_camera  : head camera sensor for gz sim (needs the sensors system
                        in the world - drona_bringup/worlds/drona_advising.sdf).
       use_gz_control : per-joint PID position controllers + joint-state
                        publisher so the gz model mirrors /drona/joint_states
                        (relayed by drona_ros gz_joint_relay). -->
  <xacro:arg name="use_gz_camera" default="false"/>
  <xacro:arg name="use_gz_control" default="false"/>

  <!-- ── Materials ─────────────────────────────────────────────────────────── -->
  <material name="drona_crimson"><color rgba="0.78 0.10 0.23 1.0"/></material>
  <material name="drona_slate"><color rgba="0.25 0.28 0.34 1.0"/></material>
  <material name="drona_green"><color rgba="0.30 0.80 0.30 1.0"/></material>
  <material name="drona_red"><color rgba="0.80 0.30 0.30 1.0"/></material>
  <material name="drona_yellow"><color rgba="0.85 0.80 0.30 1.0"/></material>
  <material name="drona_blue"><color rgba="0.35 0.45 0.90 1.0"/></material>
  <material name="drona_skin"><color rgba="0.90 0.78 0.68 1.0"/></material>

  <!-- Reusable inertial macro (small solid-ish box approximation). -->
  <xacro:macro name="box_inertial" params="mass">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass*0.002}" ixy="0" ixz="0"
               iyy="${mass*0.002}" iyz="0" izz="${mass*0.002}"/>
    </inertial>
  </xacro:macro>

  <!-- ── Torso (root) ──────────────────────────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry><box size="0.22 0.14 0.40"/></geometry>
      <material name="drona_slate"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.20"/>
      <geometry><box size="0.22 0.14 0.40"/></geometry>
    </collision>
    <xacro:box_inertial mass="2.0"/>
  </link>

  <!-- Head (fixed) -->
  <link name="head_link">
    <visual>
      <geometry><sphere radius="0.09"/></geometry>
      <material name="drona_skin"/>
    </visual>
    <collision><geometry><sphere radius="0.09"/></geometry></collision>
    <xacro:box_inertial mass="0.6"/>
  </link>
  <joint name="neck_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="head_link"/>
    <origin xyz="0 0 0.50"/>
  </joint>

  <!-- Shoulder mount (fixed offset to the right shoulder) -->
  <link name="arm_base">
    <visual>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="drona_crimson"/>
    </visual>
    <collision><geometry><cylinder radius="0.04" length="0.05"/></geometry></collision>
    <xacro:box_inertial mass="0.5"/>
  </link>
  <joint name="shoulder_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base"/>
    <origin xyz="0 -0.13 0.36"/>
  </joint>

  <!-- ── j0: base yaw ─────────────────────────────────────────────────────── -->
  <link name="shoulder_link">
    <visual>
      <geometry><cylinder radius="0.035" length="0.04"/></geometry>
      <material name="drona_crimson"/>
    </visual>
    <collision><geometry><cylinder radius="0.035" length="0.04"/></geometry></collision>
    <xacro:box_inertial mass="0.3"/>
  </link>
  <joint name="j0_base_yaw" type="revolute">
    <parent link="arm_base"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.04"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="3.0"/>
  </joint>

  <!-- ── j1: shoulder pitch ───────────────────────────────────────────────── -->
  <link name="upper_arm">
    <visual>
      <origin xyz="0 0 0.075"/>
      <geometry><cylinder radius="0.025" length="0.15"/></geometry>
      <material name="drona_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075"/>
      <geometry><cylinder radius="0.025" length="0.15"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.3"/>
  </link>
  <joint name="j1_shoulder" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.02"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="10" velocity="3.0"/>
  </joint>

  <!-- ── j2: elbow ────────────────────────────────────────────────────────── -->
  <link name="forearm">
    <visual>
      <origin xyz="0 0 0.06"/>
      <geometry><cylinder radius="0.02" length="0.12"/></geometry>
      <material name="drona_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.06"/>
      <geometry><cylinder radius="0.02" length="0.12"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.2"/>
  </link>
  <joint name="j2_elbow" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.15"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="8" velocity="3.0"/>
  </joint>

  <!-- ── j3: wrist pitch ──────────────────────────────────────────────────── -->
  <link name="wrist_pitch_link">
    <visual>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.015" length="0.07"/></geometry>
      <material name="drona_yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.035"/>
      <geometry><cylinder radius="0.015" length="0.07"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.1"/>
  </link>
  <joint name="j3_wrist_pitch" type="revolute">
    <parent link="forearm"/>
    <child link="wrist_pitch_link"/>
    <origin xyz="0 0 0.12"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="5" velocity="3.0"/>
  </joint>

  <!-- ── j4: wrist roll ───────────────────────────────────────────────────── -->
  <link name="wrist_roll_link">
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry><cylinder radius="0.012" length="0.04"/></geometry>
      <material name="drona_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02"/>
      <geometry><cylinder radius="0.012" length="0.04"/></geometry>
    </collision>
    <xacro:box_inertial mass="0.05"/>
  </link>
  <joint name="j4_wrist_roll" type="revolute">
    <parent link="wrist_pitch_link"/>
    <child link="wrist_roll_link"/>
    <origin xyz="0 0 0.07"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="5" velocity="3.0"/>
  </joint>

  <!-- ── j5: gripper (prismatic) ──────────────────────────────────────────── -->
  <link name="gripper_link">
    <visual>
      <geometry><box size="0.03 0.02 0.02"/></geometry>
      <material name="drona_crimson"/>
    </visual>
    <collision><geometry><box size="0.03 0.02 0.02"/></geometry></collision>
    <xacro:box_inertial mass="0.02"/>
  </link>
  <joint name="j5_gripper" type="prismatic">
    <parent link="wrist_roll_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.04"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.0" upper="1.0" effort="3" velocity="1.0"/>
  </joint>

  <!-- ── Head camera (perception sensor) ──────────────────────────────────────
       The physical deployment uses a webcam at eye level; this frame is its
       TF anchor in every mode, and in Gazebo it also carries the simulated
       camera sensor. camera_optical_frame follows REP-103 (z forward). -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.02 0.05 0.02"/></geometry>
      <material name="drona_slate"/>
    </visual>
    <collision><geometry><box size="0.02 0.05 0.02"/></geometry></collision>
    <xacro:box_inertial mass="0.02"/>
  </link>
  <joint name="camera_fixed" type="fixed">
    <parent link="head_link"/>
    <child link="camera_link"/>
    <origin xyz="0.085 0 0.02"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_fixed" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ── Gazebo camera sensor (sim only) ────────────────────────────────────── -->
  <xacro:if value="$(arg use_gz_camera)">
    <gazebo reference="camera_link">
      <sensor name="drona_head_camera" type="camera">
        <topic>drona/camera/image_raw</topic>
        <update_rate>15</update_rate>
        <always_on>1</always_on>
        <visualize>true</visualize>
        <gz_frame_id>camera_optical_frame</gz_frame_id>
        <camera>
          <horizontal_fov>1.204</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.05</near><far>10.0</far></clip>
          <camera_info_topic>drona/camera/camera_info</camera_info_topic>
        </camera>
      </sensor>
    </gazebo>
  </xacro:if>

  <!-- ── Gazebo joint control (sim only) ──────────────────────────────────────
       PID position controllers per joint; the drona_ros gz_joint_relay node
       converts /drona/joint_states into these per-joint command topics (bridged
       to gz.msgs.Double), so the gz model performs the same gestures as the
       policy publishes - the sim mirrors deployment exactly. -->
  <xacro:if value="$(arg use_gz_control)">
    <gazebo>
      <plugin filename="gz-sim-joint-state-publisher-system"
              name="gz::sim::systems::JointStatePublisher"/>
      <xacro:macro name="gz_joint_pid" params="joint">
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
          <joint_name>${joint}</joint_name>
          <topic>drona/gz/${joint}_cmd</topic>
          <p_gain>20.0</p_gain>
          <i_gain>0.5</i_gain>
          <d_gain>1.0</d_gain>
        </plugin>
      </xacro:macro>
      <xacro:gz_joint_pid joint="j0_base_yaw"/>
      <xacro:gz_joint_pid joint="j1_shoulder"/>
      <xacro:gz_joint_pid joint="j2_elbow"/>
      <xacro:gz_joint_pid joint="j3_wrist_pitch"/>
      <xacro:gz_joint_pid joint="j4_wrist_roll"/>
      <xacro:gz_joint_pid joint="j5_gripper"/>
    </gazebo>
  </xacro:if>

</robot>
